# All optional in Milestone 1 — the app works with zero external calls.
ENABLE_LLM_CURATION=false
OPENROUTER_API_KEY=
# Chatbot (bottom-right widget). Model is OpenRouter, OpenAI-compatible; default is the free owl-alpha.
OPENROUTER_CHAT_MODEL=openrouter/owl-alpha
# Optional: your site URL for OpenRouter leaderboard attribution.
OPENROUTER_SITE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
